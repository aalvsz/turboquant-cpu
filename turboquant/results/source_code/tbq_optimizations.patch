+        for (int j = 0; j < QK_TBQ; ++j) {
+            sumi += (int)tbq_centroids_i8_2bit[(x[ib].qs[j >> 2] >> ((j & 3) << 1)) & 0x3] * (int)y[ib].qs[j];
