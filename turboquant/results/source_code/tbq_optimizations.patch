+        __m128i sum_lo = _mm_setzero_si128();
+        __m128i sum_hi = _mm_setzero_si128();
+        for (int half = 0; half < 2; ++half) {
+            const __m128i ql4  = _mm_cvtsi32_si128(*(const uint32_t *)&x[ib].qs[half * 4]);
+            const __m128i ql16 = _mm_shuffle_epi8(ql4, rep4_lo);
+            const __m128i g0 = _mm_and_si128(ql16, m3);
