+            _mm256_storeu_ps(o, _mm256_fmadd_ps(scalev, c, _mm256_loadu_ps(o)));
+        }
+    }
+#else
     for (int i = 0; i < nb; i++) {
         const float s = GGML_CPU_FP16_TO_FP32(x[i].d) * scale;
         float sc[4];
@@ -81,11 +108,58 @@ void ggml_vec_mad_tbq2(int n, float * GGML_RESTRICT VKQ32, const void * GGML_RES
         for (int j = 0; j < QK_TBQ; j++)
             out[j] += sc[(x[i].qs[j >> 2] >> ((j & 3) << 1)) & 0x3];
     }
+#endif
 }
 
 void ggml_vec_mad_tbq3(int n, float * GGML_RESTRICT VKQ32, const void * GGML_RESTRICT vx, float scale) {
     const block_tbq3 * GGML_RESTRICT x = vx;
     const int nb = n / QK_TBQ;
+#if defined(__AVX2__)
+    // Float centroid LUT (8 entries)
+    const __m256 centroids_f = _mm256_set_ps(
+        tbq_centroids_3bit[7], tbq_centroids_3bit[6],
+        tbq_centroids_3bit[5], tbq_centroids_3bit[4],
+        tbq_centroids_3bit[3], tbq_centroids_3bit[2],
+        tbq_centroids_3bit[1], tbq_centroids_3bit[0]);
+
+    for (int i = 0; i < nb; i++) {
+        float * out = VKQ32 + i * QK_TBQ;
+        const __m256 scalev = _mm256_set1_ps(GGML_CPU_FP16_TO_FP32(x[i].d) * scale);
+
+        // Load ql (8 bytes) and qh (4 bytes)
+        const uint64_t ql = *(const uint64_t *)x[i].ql;
+        const uint32_t qh = *(const uint32_t *)x[i].qh;
+
+        // Process 4 chunks of 8 values each
+        // ql: each chunk uses 16 bits (2 bytes), shifts [0,2,4,6,8,10,12,14] of the 16-bit value
+        // qh: each chunk uses 8 bits (1 byte), shifts [0,1,2,3,4,5,6,7] of the 8-bit value
+        const __m256i ql_shifts = _mm256_setr_epi32(0, 2, 4, 6, 8, 10, 12, 14);
+        const __m256i qh_shifts = _mm256_setr_epi32(0, 1, 2, 3, 4, 5, 6, 7);
+        const __m256i m3_32 = _mm256_set1_epi32(3);
+        const __m256i m1_32 = _mm256_set1_epi32(1);
+
+        for (int chunk = 0; chunk < 4; chunk++) {
+            // ql: 16 bits containing 8 × 2-bit
+            const uint32_t ql_bytes = (ql >> (chunk * 16)) & 0xFFFF;
+            const __m256i ql_b = _mm256_set1_epi32(ql_bytes);
+            const __m256i lo = _mm256_and_si256(_mm256_srlv_epi32(ql_b, ql_shifts), m3_32);
+
+            // qh: 8 bits containing 8 × 1-bit
+            const uint32_t qh_bytes = (qh >> (chunk * 8)) & 0xFF;
+            const __m256i qh_b = _mm256_set1_epi32(qh_bytes);
+            const __m256i hi_bit = _mm256_and_si256(_mm256_srlv_epi32(qh_b, qh_shifts), m1_32);
+
+            // Combine: idx = lo | (hi << 2)
+            const __m256i hi_shifted = _mm256_slli_epi32(hi_bit, 2);
+            const __m256i idx = _mm256_or_si256(lo, hi_shifted);
+
+            // Float lookup + FMA
+            const __m256 c = _mm256_permutevar8x32_ps(centroids_f, idx);
+            float * o = out + chunk * 8;
+            _mm256_storeu_ps(o, _mm256_fmadd_ps(scalev, c, _mm256_loadu_ps(o)));
+        }
+    }
+#else
     for (int i = 0; i < nb; i++) {
         const float s = GGML_CPU_FP16_TO_FP32(x[i].d) * scale;
         float sc[8];
@@ -97,22 +171,50 @@ void ggml_vec_mad_tbq3(int n, float * GGML_RESTRICT VKQ32, const void * GGML_RES
             out[j] += sc[lo | (hi << 2)];
         }
     }
+#endif
 }
 
 void ggml_vec_mad_tbq4(int n, float * GGML_RESTRICT VKQ32, const void * GGML_RESTRICT vx, float scale) {
     const block_tbq4 * GGML_RESTRICT x = vx;
     const int nb = n / QK_TBQ;
+#if defined(__AVX2__)
+    const __m128i centroids128 = _mm_loadu_si128((const __m128i *)tbq_centroids_i8_4bit);
+    const __m128i m4b = _mm_set1_epi8(0x0F);
+
+    for (int i = 0; i < nb; i++) {
+        float * out = VKQ32 + i * QK_TBQ;
+        const __m128i qbits = _mm_loadu_si128((const __m128i *)x[i].qs);
+        const __m128i qlo = _mm_and_si128(qbits, m4b);
+        const __m128i qhi = _mm_and_si128(_mm_srli_epi16(qbits, 4), m4b);
+        const __m256 scalev = _mm256_set1_ps(GGML_CPU_FP16_TO_FP32(x[i].d) * scale * tbq_dscale_4bit);
+
+        {
+            const __m128i cbytes = _mm_shuffle_epi8(centroids128, qlo);
+            const __m256 f0 = _mm256_cvtepi32_ps(_mm256_cvtepi8_epi32(cbytes));
+            const __m256 f1 = _mm256_cvtepi32_ps(_mm256_cvtepi8_epi32(_mm_srli_si128(cbytes, 8)));
+            _mm256_storeu_ps(out + 0, _mm256_fmadd_ps(scalev, f0, _mm256_loadu_ps(out + 0)));
+            _mm256_storeu_ps(out + 8, _mm256_fmadd_ps(scalev, f1, _mm256_loadu_ps(out + 8)));
+        }
+        {
+            const __m128i cbytes = _mm_shuffle_epi8(centroids128, qhi);
+            const __m256 f0 = _mm256_cvtepi32_ps(_mm256_cvtepi8_epi32(cbytes));
+            const __m256 f1 = _mm256_cvtepi32_ps(_mm256_cvtepi8_epi32(_mm_srli_si128(cbytes, 8)));
+            _mm256_storeu_ps(out + 16, _mm256_fmadd_ps(scalev, f0, _mm256_loadu_ps(out + 16)));
+            _mm256_storeu_ps(out + 24, _mm256_fmadd_ps(scalev, f1, _mm256_loadu_ps(out + 24)));
+        }
+    }
+#else
     for (int i = 0; i < nb; i++) {
         const float s = GGML_CPU_FP16_TO_FP32(x[i].d) * scale;
         float sc[16];
