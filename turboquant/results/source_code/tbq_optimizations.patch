+        TBQ2_DOT_HALF(ib + 0, 0); __m128i sum_lo_1 = half_sum;
+        TBQ2_DOT_HALF(ib + 0, 1); __m128i sum_hi_1 = half_sum;
+        TBQ2_DOT_HALF(ib + 1, 0); __m128i sum_lo_2 = half_sum;
