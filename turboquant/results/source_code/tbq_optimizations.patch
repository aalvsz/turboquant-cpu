+    // Helper macro: expand 2-bit ql for one block half, multiply with Q8, return i32 sum
+#define TBQ2_DOT_HALF(BLK, HALF) do { \
+        const __m128i ql4_  = _mm_cvtsi32_si128(*(const uint32_t *)&x[(BLK)].qs[(HALF) * 4]); \
+        const __m128i ql16_ = _mm_shuffle_epi8(ql4_, rep4_lo); \
+        const __m128i g0_ = _mm_and_si128(ql16_, m3); \
+        const __m128i g1_ = _mm_and_si128(_mm_srli_epi16(ql16_, 2), m3); \
+        const __m128i g2_ = _mm_and_si128(_mm_srli_epi16(ql16_, 4), m3); \
+        const __m128i g3_ = _mm_and_si128(_mm_srli_epi16(ql16_, 6), m3); \
+        const __m128i ab_  = _mm_blendv_epi8(g0_, g1_, blend_1); \
+        const __m128i abc_ = _mm_blendv_epi8(ab_, g2_, blend_2); \
+        const __m128i idx_ = _mm_blendv_epi8(abc_, g3_, blend_3); \
+        const __m128i cents_ = _mm_shuffle_epi8(centroids128, idx_); \
+        const __m128i q8_ = _mm_loadu_si128((const __m128i *)&y[(BLK)].qs[(HALF) * 16]); \
+        const __m128i ax_ = _mm_sign_epi8(cents_, cents_); \
+        const __m128i sy_ = _mm_sign_epi8(q8_, cents_); \
+        half_sum = _mm_madd_epi16(_mm_maddubs_epi16(ax_, sy_), mone16); \
+    } while(0)
