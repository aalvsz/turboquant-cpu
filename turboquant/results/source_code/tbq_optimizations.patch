+                                           0,(char)0xFF,0,0, 0,(char)0xFF,0,0);
+    const __m128i blend_2 = _mm_setr_epi8(0,0,(char)0xFF,0, 0,0,(char)0xFF,0,
+                                           0,0,(char)0xFF,0, 0,0,(char)0xFF,0);
+    const __m128i blend_3 = _mm_setr_epi8(0,0,0,(char)0xFF, 0,0,0,(char)0xFF,
+                                           0,0,0,(char)0xFF, 0,0,0,(char)0xFF);
+
+    __m256 acc1 = _mm256_setzero_ps();
+    __m256 acc2 = _mm256_setzero_ps();
