+            const __m128i g2 = _mm_and_si128(_mm_srli_epi16(ql16, 4), m3);
+            const __m128i g3 = _mm_and_si128(_mm_srli_epi16(ql16, 6), m3);
+            __m128i ab  = _mm_blendv_epi8(g0, g1, blend_1);
+            __m128i abc = _mm_blendv_epi8(ab, g2, blend_2);
+            __m128i idx = _mm_blendv_epi8(abc, g3, blend_3);
+            const __m128i cents = _mm_shuffle_epi8(centroids128, idx);
+            const __m128i q8 = _mm_loadu_si128((const __m128i *)&y[ib].qs[half * 16]);
+            const __m128i ax = _mm_sign_epi8(cents, cents);
+            const __m128i sy = _mm_sign_epi8(q8, cents);
+            const __m128i dot16 = _mm_maddubs_epi16(ax, sy);
+            if (half == 0) sum_lo = _mm_madd_epi16(dot16, mone16);
+            else           sum_hi = _mm_madd_epi16(dot16, mone16);
+        }
+        acc1 = _mm256_fmadd_ps(
+            _mm256_set1_ps(GGML_CPU_FP16_TO_FP32(x[ib].d) * GGML_CPU_FP16_TO_FP32(y[ib].d) * tbq_dscale_2bit),
+            _mm256_cvtepi32_ps(_mm256_setr_m128i(sum_lo, sum_hi)), acc1);
+    }
