+void ggml_vec_mad_tbq2(int n, float * GGML_RESTRICT VKQ32, const void * GGML_RESTRICT vx, float scale) {
+    const block_tbq2 * GGML_RESTRICT x = vx;
+    const int nb = n / QK_TBQ;
+    for (int i = 0; i < nb; i++) {
+        const float s = GGML_CPU_FP16_TO_FP32(x[i].d) * scale;
+        float sc[4];
+        for (int k = 0; k < 4; k++) sc[k] = tbq_centroids_2bit[k] * s;
+        float * out = VKQ32 + i * QK_TBQ;
+        for (int j = 0; j < QK_TBQ; j++)
+            out[j] += sc[(x[i].qs[j >> 2] >> ((j & 3) << 1)) & 0x3];
+    }
+}
+
+void ggml_vec_mad_tbq3(int n, float * GGML_RESTRICT VKQ32, const void * GGML_RESTRICT vx, float scale) {
+    const block_tbq3 * GGML_RESTRICT x = vx;
+    const int nb = n / QK_TBQ;
+    for (int i = 0; i < nb; i++) {
+        const float s = GGML_CPU_FP16_TO_FP32(x[i].d) * scale;
+        float sc[8];
+        for (int k = 0; k < 8; k++) sc[k] = tbq_centroids_3bit[k] * s;
+        float * out = VKQ32 + i * QK_TBQ;
+        for (int j = 0; j < QK_TBQ; j++) {
+            int lo = (x[i].ql[j >> 2] >> ((j & 3) << 1)) & 0x3;
+            int hi = (x[i].qh[j >> 3] >> (j & 7)) & 1;
+            out[j] += sc[lo | (hi << 2)];
+        }
+    }
+}
+
+void ggml_vec_mad_tbq4(int n, float * GGML_RESTRICT VKQ32, const void * GGML_RESTRICT vx, float scale) {
+    const block_tbq4 * GGML_RESTRICT x = vx;
+    const int nb = n / QK_TBQ;
+    for (int i = 0; i < nb; i++) {
+        const float s = GGML_CPU_FP16_TO_FP32(x[i].d) * scale;
+        float sc[16];
+        for (int k = 0; k < 16; k++) sc[k] = tbq_centroids_4bit[k] * s;
+        float * out = VKQ32 + i * QK_TBQ;
+        // Half-split packing: low nibble = first half, high nibble = second half
+        for (int j = 0; j < QK_TBQ / 2; j++) {
+            out[j]              += sc[x[i].qs[j] & 0xF];
+            out[j + QK_TBQ / 2] += sc[x[i].qs[j] >> 4];
+        }
+    }
