+        sumf += (float)(sumi0 + sumi1) * GGML_CPU_FP16_TO_FP32(x[ib].d) * GGML_CPU_FP16_TO_FP32(y[ib].d) * tbq_dscale_4bit;
+    }
+    *s = sumf;
+}
+
+// TBQ3: split layout (ql[8] low 2 bits + qh[4] high bit)
+void ggml_vec_dot_tbq3_q8_0_generic(int n, float * GGML_RESTRICT s, size_t bs,
+        const void * GGML_RESTRICT vx, size_t bx,
+        const void * GGML_RESTRICT vy, size_t by, int nrc) {
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+    assert(n % QK_TBQ == 0);
+    const block_tbq3 * GGML_RESTRICT x = vx;
+    const block_q8_0 * GGML_RESTRICT y = vy;
+    const int nb = n / QK_TBQ;
+    float sumf = 0;
+    for (int ib = 0; ib < nb; ++ib) {
+        int sumi0 = 0, sumi1 = 0;
+        for (int j = 0; j < QK_TBQ; ++j) {
+            int lo = (x[ib].ql[j >> 2] >> ((j & 3) << 1)) & 0x3;
+            int hi = (x[ib].qh[j >> 3] >> (j & 7)) & 1;
+            int idx = lo | (hi << 2);
+            if (j < QK_TBQ/2)
+                sumi0 += (int)tbq_centroids_i8_3bit[idx] * (int)y[ib].qs[j];
+            else
+                sumi1 += (int)tbq_centroids_i8_3bit[idx] * (int)y[ib].qs[j];
+        }
+        sumf += (float)(sumi0 + sumi1) * GGML_CPU_FP16_TO_FP32(x[ib].d) * GGML_CPU_FP16_TO_FP32(y[ib].d) * tbq_dscale_3bit;
+    }
+    *s = sumf;
+}
+
+// TBQ2: 2-bit packed (4 values/byte)
+void ggml_vec_dot_tbq2_q8_0_generic(int n, float * GGML_RESTRICT s, size_t bs,
+        const void * GGML_RESTRICT vx, size_t bx,
+        const void * GGML_RESTRICT vy, size_t by, int nrc) {
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+    assert(n % QK_TBQ == 0);
+    const block_tbq2 * GGML_RESTRICT x = vx;
+    const block_q8_0 * GGML_RESTRICT y = vy;
+    const int nb = n / QK_TBQ;
+    float sumf = 0;
+    for (int ib = 0; ib < nb; ++ib) {
+        int sumi0 = 0, sumi1 = 0;
+        // 8 bytes = 32 2-bit values. Process 4 values per byte.
+        for (int j = 0; j < 4; ++j) {
+            uint8_t b0 = x[ib].qs[j];
+            uint8_t b1 = x[ib].qs[j + 4];
+            sumi0 += (int)tbq_centroids_i8_2bit[(b0 >> 0) & 3] * (int)y[ib].qs[j*4 + 0];
+            sumi0 += (int)tbq_centroids_i8_2bit[(b0 >> 2) & 3] * (int)y[ib].qs[j*4 + 1];
+            sumi0 += (int)tbq_centroids_i8_2bit[(b0 >> 4) & 3] * (int)y[ib].qs[j*4 + 2];
+            sumi0 += (int)tbq_centroids_i8_2bit[(b0 >> 6) & 3] * (int)y[ib].qs[j*4 + 3];
+            sumi1 += (int)tbq_centroids_i8_2bit[(b1 >> 0) & 3] * (int)y[ib].qs[16 + j*4 + 0];
+            sumi1 += (int)tbq_centroids_i8_2bit[(b1 >> 2) & 3] * (int)y[ib].qs[16 + j*4 + 1];
+            sumi1 += (int)tbq_centroids_i8_2bit[(b1 >> 4) & 3] * (int)y[ib].qs[16 + j*4 + 2];
+            sumi1 += (int)tbq_centroids_i8_2bit[(b1 >> 6) & 3] * (int)y[ib].qs[16 + j*4 + 3];
+        }
+        sumf += (float)(sumi0 + sumi1) * GGML_CPU_FP16_TO_FP32(x[ib].d) * GGML_CPU_FP16_TO_FP32(y[ib].d) * tbq_dscale_2bit;
+    }
+    *s = sumf;
+}
+
